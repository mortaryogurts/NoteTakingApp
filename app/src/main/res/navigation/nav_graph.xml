<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.notetakingapp.views.HomeFragment"
        android:label="Notes"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_newNoteFragment"
            app:destination="@id/newNoteFragment" />
        <action
            android:id="@+id/action_homeFragment_to_updateNoteFragment"
            app:destination="@id/updateNoteFragment" />
    </fragment>
    <fragment
        android:id="@+id/newNoteFragment"
        android:name="com.example.notetakingapp.views.NewNoteFragment"
        android:label="Add Note"
        tools:layout="@layout/fragment_new_note" >
        <action
            android:id="@+id/action_newNoteFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/updateNoteFragment"
        android:name="com.example.notetakingapp.views.UpdateNoteFragment"
        android:label="Update Note"
        tools:layout="@layout/fragment_update_note" >
        <action
            android:id="@+id/action_updateNoteFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <argument
            android:name="note"
            app:argType="com.example.notetakingapp.model.Note"
            app:nullable="true"/>
    </fragment>
    <fragment
        android:id="@+id/archiveFragment"
        android:name="com.example.notetakingapp.views.ArchiveFragment"
        android:label="fragment_archive"
        tools:layout="@layout/fragment_archive" />
    <action
        android:id="@+id/action_homeFragment_to_archiveFragment"
        app:destination="@id/archiveFragment"/>
    <fragment
        android:id="@+id/trashFragment"
        android:name="com.example.notetakingapp.views.TrashFragment"
        android:label="fragment_trash"
        tools:layout="@layout/fragment_trash" />
    <action
        android:id="@+id/action_homeFragment_to_trashFragment"
        app:destination="@id/trashFragment"/>
</navigation>